# ── Groq API ──────────────────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_...
# Model options: llama-3.3-70b-versatile | llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile

# ── LinkedIn API ──────────────────────────────────────────────────────────────
# Generate at: https://www.linkedin.com/developers/
# Required scopes: openid, profile, w_member_social
LINKEDIN_ACCESS_TOKEN=

# LinkedIn OAuth credentials (used by linkedin_auth.py to get a new token)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Optional — auto-resolved from /userinfo if left blank
# Format: urn:li:person:<id>
LINKEDIN_PERSON_URN=

# Optional — your LinkedIn company/organization URN
# Find it at: https://www.linkedin.com/company/<name>/admin/ (URL shows the numeric ID)
# Format: urn:li:organization:<numeric_id>
# When set, the "Also post to Company Page" checkbox in the Publish tab will work
LINKEDIN_ORG_URN=

# ── Unsplash API ───────────────────────────────────────────────────────────────
# Free key at: https://unsplash.com/developers  (50 req/hour, no cost)
# Leave blank to skip image fetching
UNSPLASH_ACCESS_KEY=

# ── Website repo ──────────────────────────────────────────────────────────────
# Local path to your phoenixsolution website git repository
WEBSITE_REPO_PATH=C:\Projects\phoenixsolution
